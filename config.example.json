{
  "main_log": "./logs/net-dump.txt",
  "request_logs": "./logs/requests",
  "mappings": [
    {
      "name": "8090",
      "in": {
        "port": 8091,
        "interface": "0.0.0.0",
        "ssl": {
          "key": "../thunder/target/out/.cert/server.key",
          "cert": "../thunder/target/out/.cert/server.cert"
        }
      },
      "out": {
        "host": "localhost",
        "port": 8090,
        "https": true
      }
    }
  ]
}